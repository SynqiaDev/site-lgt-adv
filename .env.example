# =============================================================================
# Dados da empresa e configuração do site — LP Energia Solar
# =============================================================================
# Copie este arquivo para .env e preencha com os dados reais.
# Nunca commite o arquivo .env (ele está no .gitignore).
# Todas as variáveis abaixo são usadas no front (NEXT_PUBLIC_*).
# =============================================================================

# URL canônica do site (metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://www.exemplo.com.br

# Dados básicos da empresa
NEXT_PUBLIC_COMPANY_NAME=SuaEmpresa
NEXT_PUBLIC_WHATSAPP=5500000000000
NEXT_PUBLIC_PHONE=(00) 00000-0000
NEXT_PUBLIC_EMAIL=contato@exemplo.com.br
NEXT_PUBLIC_BUSINESS_HOURS=Segunda a Sexta: 8h às 18h

# Redes sociais — JSON. Campos opcionais: instagram, youtube, facebook, podcast.
# Cada um: { "url": "...", "label": "..." }
NEXT_PUBLIC_COMPANY_SOCIAL={"instagram":{"url":"https://instagram.com/sua_empresa","label":"@sua_empresa"},"youtube":{"url":"https://youtube.com/@sua_empresa","label":"Canal no YouTube"},"facebook":{"url":"https://facebook.com/sua_empresa","label":"Página no Facebook"}}

# Unidades / endereços — JSON array. Cada item: name, address, phones (array), mapsEmbedUrl, mapsLinkUrl
NEXT_PUBLIC_COMPANY_UNITS=[{"name":"Cidade 1 / UF","address":"Rua Exemplo, 123, Bairro","phones":["(00) 0000-0000"],"mapsEmbedUrl":"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3657.0!2d-46.0!3d-23.0!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMcKwMDAnMDAuMCJTIDQ2wrAwMCcwMC4wIlc!5e0!3m2!1spt-BR!2sbr!4v0","mapsLinkUrl":"https://www.google.com/maps/search/?api=1&query=Rua+Exemplo,+123"}]

# Opções do select "Do que você precisa?" no formulário — JSON array de strings
NEXT_PUBLIC_QUOTE_OPTIONS=["Energia solar","Instalação elétrica","Projeto elétrico","Automação","Outro"]

# =============================================================================
# Analytics (opcional — carregados apenas após consentimento de cookies)
# =============================================================================
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXX
